      m_Calls: []
  m_text: "NIGHT OF THE HORDE\r\n\r\nPROJECT TEAM\r\n\r\nProject Manager\r\nDaniel
    Acosta\n\r\nAssistant Project Manager\r\nNicolas Rangel\r\n\r\nSoftware Engineers\r\nJacob
    Caro\nCarlos Delgadillo\nTevinn Howard\r\nRuixuan Huang\r\n\nQA Lead\nJuan Ortez\n\nGAME
    SYSTEMS\r\n\nMap Design/Layout\nJacob Caro\n\r\nPlayer Movement, Sprint, Dash,
    and Stamina System\r\nCarlos Delgadillo\r\n\r\nShooting and Melee Combat System\r\nTevinn
    Howard\n\r\nZombie AI Systems\r\nTevinn Howard\r\n\r\nWave Spawning System\r\nTevinn
    Howard\r\n\r\nSettings, and UI Systems\r\nRuixuan Huang\r\n\r\nHigh Scores and
    Game Over System\r\nRuixuan Huang\n\r\r\nAI / PATHFINDING\r\n\nSmart Zombie AI\r\nPowered
    by A* Pathfinding Project.\r\n\r\nA* Pathfinding Project\r\nCreated by Aron Granberg.\r\r\n\nART
    / MAP ASSETS\r\n\r\nMap / Environment Assets\r\nPixel Art Top Down\nCreated by
    Cainos\n\r\nPlayer Sprite / Character Assets\r\r\nCreated by Nicolas Rangel\n\r\nZombie
    Sprite Assets\r\r\nCreated by Nicolas Rangel\r\n\r\r\nAUDIO\r\n\r\nMenu Music/Gameplay
    Music\r\nDark Sanctuary\r\nCreated by Griffin Silbey\r\n\r\nHard Mode Music\r\n\rNo
    Way Back Demo\nCreated by Andrew Sitkov Music\r\n\r\nSound Effects\r\nPost Apocalypse
    Guns Demo\nCreated by Sound Earth Game Audio\n\nZombie Sound Pack - Free Version\nCreated
    by Catastic\n\r\r\nTOOLS / SOFTWARE\r\n\r\nUnity Game Engine\r\nUnity Technologies\r\n\r\nTextMeshPro\r\nUnity
    Technologies\r\n\r\nA* Pathfinding Project\r\nAron Granberg\r\n\r\r\nSPECIAL
    THANKS\r\n\r\nThank you to everyone who helped test, review, and support this
    project."
  m_isRightToLeft: 0
